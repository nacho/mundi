<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.nacho.mundi</id>

  <name>Mundi</name>

  <summary>Learn geography</summary>
  <summary xml:lang="es">Aprende geografía</summary>

  <developer_name>Ignacio Casal Quinteiro</developer_name>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <branding>
    <color type="primary" scheme_preference="light">#9141ac</color>
    <color type="primary" scheme_preference="dark">#613583</color>
  </branding>

  <description>
    <p>
      Mundi is a geography learning application for the GNOME desktop.
      Explore interactive maps in discovery mode to learn regions, countries and
      continents, then test your knowledge with timed quizzes.
    </p>
    <p xml:lang="es">
      Mundi es una aplicación de aprendizaje de geografía para el escritorio GNOME.
      Explora mapas interactivos en modo descubrimiento para aprender regiones, países y
      continentes, y luego pon a prueba tus conocimientos con cuestionarios cronometrados.
    </p>
    <p>
      Features include discovery mode for free exploration, timed quizzes with
      score tracking, multiple exercises per country, and a results view to
      review your performance.
    </p>
    <p xml:lang="es">
      Las características incluyen modo descubrimiento para exploración libre,
      cuestionarios cronometrados con seguimiento de puntuación, múltiples
      ejercicios por país y una vista de resultados para revisar tu rendimiento.
    </p>
  </description>

  <launchable type="desktop-id">io.github.nacho.mundi.desktop</launchable>

  <url type="homepage">https://github.com/nacho/mundi</url>
  <url type="vcs-browser">https://github.com/nacho/mundi</url>

  <categories>
    <category>Education</category>
    <category>Geography</category>
  </categories>

  <content_rating type="oars-1.1" />

