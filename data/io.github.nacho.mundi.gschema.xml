<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="io.github.nacho.mundi" path="/io/github/nacho/mundi/">
    <child name="state" schema="io.github.nacho.mundi.state"/>
  </schema>

  <schema id="io.github.nacho.mundi.state" path="/io/github/nacho/mundi/state/">
    <child name="window" schema="io.github.nacho.mundi.state.window"/>
  </schema>

  <schema id="io.github.nacho.mundi.state.window" path="/io/github/nacho/mundi/state/window/">
    <key name="maximized" type="b">
      <default>false</default>
    </key>
    <key name="size" type="(ii)">
      <default>(900, 700)</default>
    </key>
  </schema>

  <schema id="io.github.nacho.mundi.stats">
    <key name="correct" type="u">
      <default>0</default>
      <summary>Correct answers</summary>
    </key>
    <key name="total" type="u">
      <default>0</default>
      <summary>Total questions</summary>
    </key>
  </schema>
</schemalist>
